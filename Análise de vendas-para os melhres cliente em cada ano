import pandas as pd
import matplotlib.pyplot as plt

def top_5_clientes_por_ano(df):
    """
    Mostra os 5 melhores clientes (maior valor de compras) por ano
    """
    
    # Lista de anos disponíveis
    anos = sorted(df['Ano'].unique())
    
    print("="*80)
    print("TOP 5 CLIENTES POR ANO (MAIOR VALOR DE COMPRAS)")
    print("="*80)
    
    # Dicionário para armazenar os top 5 de cada ano
    top5_por_ano = {}
    
    for ano in anos:
        # Filtrar dados do ano
        df_ano = df[df['Ano'] == ano]
        
        # Agrupar por cliente e somar valor total
        vendas_por_cliente = df_ano.groupby(['ID_Cliente', 'Nome_Cliente', 'Porte_Cliente']).agg({
            'Valor_Total': 'sum',
            'ID_Pedido': 'count'
        }).rename(columns={'ID_Pedido': 'Numero_Pedidos'}).reset_index()
        
        # Ordenar por valor total e pegar top 5
        top_5 = vendas_por_cliente.nlargest(5, 'Valor_Total').reset_index(drop=True)
        top_5['Rank'] = range(1, 6)
        
        # Armazenar
        top5_por_ano[ano] = top_5
        
        # Exibir resultados
        print(f"\n{'='*80}")
        print(f"ANO {ano}")
        print(f"{'='*80}")
        print(f"Total de vendas no ano: R$ {df_ano['Valor_Total'].sum():,.2f}")
        print(f"\n{'Rank':<6} {'ID_Cliente':<15} {'Nome_Cliente':<30} {'Porte':<10} {'Valor_Total':<15} {'Pedidos'}")
        print(f"{'-'*80}")
        
        for _, row in top_5.iterrows():
            print(f"{row['Rank']:<6} {row['ID_Cliente']:<15} {row['Nome_Cliente']:<30} {row['Porte_Cliente']:<10} R$ {row['Valor_Total']:>12,.2f}  {row['Numero_Pedidos']:>3}")
        
        # Mostrar quanto os top 5 representam do total
        percentual = (top_5['Valor_Total'].sum() / df_ano['Valor_Total'].sum()) * 100
        print(f"\nTop 5 clientes representam: {percentual:.1f}% das vendas do ano")
    
    return top5_por_ano

def visualizar_top5_simplificado(top5_por_ano):
    """
    Visualização simples dos top 5 clientes por ano
    """
    
    anos = list(top5_por_ano.keys())
    
    # Criar figura
    fig, axes = plt.subplots(2, 3, figsize=(18, 12))
    axes = axes.flatten()
    
    for idx, ano in enumerate(anos):
        if idx < len(axes):
            ax = axes[idx]
            
            top5 = top5_por_ano[ano]
            
            # Criar barras horizontais
            cores = plt.cm.Blues_r(range(50, 250, 40))
            barras = ax.barh(range(5), top5['Valor_Total'], color=cores)
            
            # Adicionar valores nas barras
            for i, (valor, cliente) in enumerate(zip(top5['Valor_Total'], top5['ID_Cliente'])):
                ax.text(valor, i, f'  R$ {valor:,.0f}', va='center', fontsize=9)
            
            ax.set_yticks(range(5))
            ax.set_yticklabels([f"{row['ID_Cliente']}\n({row['Nome_Cliente'][:15]})" for _, row in top5.iterrows()])
            ax.set_xlabel('Valor Total de Compras (R$)')
            ax.set_title(f'Ano {ano} - Top 5 Clientes', fontweight='bold')
            ax.invert_yaxis()
            ax.grid(True, alpha=0.3, axis='x')
    
    # Esconder subplots não utilizados
    for idx in range(len(anos), len(axes)):
        axes[idx].set_visible(False)
    
    plt.suptitle('TOP 5 CLIENTES POR ANO (Maior Valor de Compras)', fontsize=16, fontweight='bold')
    plt.tight_layout()
    plt.show()


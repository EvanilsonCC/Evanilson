import pandas as pd
import numpy as np
from datetime import datetime, timedelta
import random

# Fixar seed para reprodutibilidade
np.random.seed(42)
random.seed(42)

def gerar_dados_vendas_5_anos(num_registros=97000):
    """
    Gera dados de vendas para os últimos 5 anos
    """
    
    # Clientes (100 clientes com diferentes perfis)
    clientes = {
        f'Cliente_{i:03d}': {
            'nome': f'Empresa {chr(65 + i % 26)}{i}',
            'porte': np.random.choice(['Pequeno', 'Médio', 'Grande'], p=[0.3, 0.4, 0.3])
        }
        for i in range(1, 101)
    }
    
    # Produtos
    produtos = {
        'Laptop Gamer': {'categoria': 'Eletrônicos', 'preco': 7500.00},
        'Mouse Vertical': {'categoria': 'Acessórios', 'preco': 250.00},
        'Teclado Mecânico': {'categoria': 'Acessórios', 'preco': 550.00},
        'Monitor Ultrawide': {'categoria': 'Eletrônicos', 'preco': 2800.00},
        'Cadeira Gamer': {'categoria': 'Móveis', 'preco': 1200.00},
        'Headset 7.1': {'categoria': 'Acessórios', 'preco': 800.00},
        'Placa de Vídeo': {'categoria': 'Hardware', 'preco': 4500.00},
        'SSD 1TB': {'categoria': 'Hardware', 'preco': 600.00}
    }
    
    lista_produtos = list(produtos.keys())
    
    # Datas dos últimos 5 anos
    data_fim = datetime(2026, 4, 18)
    data_inicio = datetime(2021, 1, 1)
    
    dados_vendas = []
    
    print(f"Gerando {num_registros} registros de vendas para 5 anos...")
    
    # CORREÇÃO: Separar clientes por porte ANTES do loop
    clientes_pequenos = [c for c in clientes if clientes[c]['porte'] == 'Pequeno']
    clientes_medios = [c for c in clientes if clientes[c]['porte'] == 'Médio']
    clientes_grandes = [c for c in clientes if clientes[c]['porte'] == 'Grande']
    
    print(f"Clientes por porte: Pequeno={len(clientes_pequenos)}, Médio={len(clientes_medios)}, Grande={len(clientes_grandes)}")
    
    for i in range(num_registros):
        
        # CORREÇÃO: Selecionar porte do cliente primeiro (10% pequeno, 30% médio, 60% grande)
        porte_selecionado = np.random.choice(['Pequeno', 'Médio', 'Grande'], p=[0.1, 0.3, 0.6])
        
        # Depois selecionar um cliente aleatório do porte escolhido
        if porte_selecionado == 'Pequeno':
            id_cliente = np.random.choice(clientes_pequenos)
        elif porte_selecionado == 'Médio':
            id_cliente = np.random.choice(clientes_medios)
        else:  # Grande
            id_cliente = np.random.choice(clientes_grandes)
        
        produto = np.random.choice(lista_produtos, p=[0.15, 0.15, 0.1, 0.1, 0.1, 0.1, 0.15, 0.15])
        
        quantidade = np.random.randint(1, 20)
        
        # Data aleatória nos últimos 5 anos
        dias_desde_inicio = (data_fim - data_inicio).days
        data_pedido = data_inicio + timedelta(days=np.random.randint(0, dias_desde_inicio))
        ano = data_pedido.year
        
        # Preço com pequena variação
        preco_base = produtos[produto]['preco']
        preco_final = preco_base * np.random.uniform(0.95, 1.05)
        
        valor_total = preco_final * quantidade
        
        dados_vendas.append({
            'ID_Pedido': 100000 + i,
            'Data_Pedido': data_pedido,
            'Ano': ano,
            'ID_Cliente': id_cliente,
            'Nome_Cliente': clientes[id_cliente]['nome'],
            'Porte_Cliente': clientes[id_cliente]['porte'],
            'Produto': produto,
            'Categoria': produtos[produto]['categoria'],
            'Quantidade': quantidade,
            'Preco_Unitario': round(preco_final, 2),
            'Valor_Total': round(valor_total, 2)
        })
        
        if (i + 1) % 10000 == 0:
            print(f"  {i+1} registros gerados...")
    
    df = pd.DataFrame(dados_vendas)
    print(f"Geração concluída! {len(df)} registros criados.")
    
    # Verificar distribuição real dos portes
    print("\nDistribuição real dos clientes nas vendas:")
    print(df['Porte_Cliente'].value_counts(normalize=True))
    
    return df

# Gerar os dados
df_vendas = gerar_dados_vendas_5_anos(97000)
